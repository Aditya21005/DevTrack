# DevTrack AI production environment template
# Store these values in your platform secret manager, not in git.

DEVTRACK_ENVIRONMENT=production
DEVTRACK_DEBUG=false
DEVTRACK_APP_NAME=DevTrack AI
DEVTRACK_ALLOWED_HOSTS=app.example.com,api.example.com
DEVTRACK_CORS_ALLOWED_ORIGINS=https://app.example.com
DEVTRACK_DATABASE_URL=postgresql+psycopg://devtrack:<password>@<managed-postgres-host>:5432/devtrack_ai
DEVTRACK_DATABASE_POOL_SIZE=10
DEVTRACK_DATABASE_MAX_OVERFLOW=20
DEVTRACK_DATABASE_POOL_TIMEOUT_SECONDS=30
DEVTRACK_DATABASE_POOL_RECYCLE_SECONDS=1800
DEVTRACK_DATABASE_POOL_USE_LIFO=true
DEVTRACK_LOG_LEVEL=INFO
DEVTRACK_LOG_FORMAT=json
DEVTRACK_JWT_ACCESS_SECRET_KEY=<32-plus-character-secret>
DEVTRACK_JWT_REFRESH_SECRET_KEY=<different-32-plus-character-secret>
DEVTRACK_JWT_ISSUER=devtrack-ai
DEVTRACK_JWT_AUDIENCE=devtrack-ai-api
DEVTRACK_ACCESS_TOKEN_EXPIRES_MINUTES=15
DEVTRACK_REFRESH_TOKEN_EXPIRES_DAYS=30
VITE_API_BASE_URL=/api
VITE_USE_MOCK_API=false
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_RATE_LIMIT_PER_MINUTE=60
GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>
GITHUB_REDIRECT_URI=https://app.example.com/integrations/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=<32-plus-character-token-encryption-key>
GITHUB_OAUTH_SCOPES=repo read:user user:email
