# DevTrack AI environment template
# Copy to .env locally or inject through your deployment platform/secret manager.

# Compose PostgreSQL
POSTGRES_DB=devtrack_ai
POSTGRES_USER=devtrack
POSTGRES_PASSWORD=change-this-local-password

# Backend runtime
DEVTRACK_APP_NAME=DevTrack AI
DEVTRACK_ENVIRONMENT=production
DEVTRACK_DEBUG=false
DEVTRACK_DATABASE_URL=postgresql+psycopg://devtrack:change-this-local-password@postgres:5432/devtrack_ai
DEVTRACK_DATABASE_POOL_SIZE=10
DEVTRACK_DATABASE_MAX_OVERFLOW=20
DEVTRACK_DATABASE_POOL_TIMEOUT_SECONDS=30
DEVTRACK_DATABASE_POOL_RECYCLE_SECONDS=1800
DEVTRACK_DATABASE_STATEMENT_TIMEOUT_MS=30000
DEVTRACK_DATABASE_LOCK_TIMEOUT_MS=5000
DEVTRACK_DATABASE_APPLICATION_NAME=devtrack-ai-api
DEVTRACK_LOG_LEVEL=INFO
DEVTRACK_LOG_FORMAT=json
DEVTRACK_ALLOWED_HOSTS=localhost,127.0.0.1
DEVTRACK_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Use different 32+ character values in every environment.
DEVTRACK_JWT_ACCESS_SECRET_KEY=replace-with-32-plus-character-access-secret
DEVTRACK_JWT_REFRESH_SECRET_KEY=replace-with-32-plus-character-refresh-secret
DEVTRACK_JWT_ISSUER=devtrack-ai
DEVTRACK_JWT_AUDIENCE=devtrack-ai-api
DEVTRACK_ACCESS_TOKEN_EXPIRES_MINUTES=15
DEVTRACK_REFRESH_TOKEN_EXPIRES_DAYS=30
DEVTRACK_PASSWORD_MIN_LENGTH=12

# Frontend build
VITE_API_BASE_URL=/api
VITE_USE_MOCK_API=false

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_RATE_LIMIT_PER_MINUTE=60
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048

# GitHub OAuth integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/integrations/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-character-token-key
GITHUB_OAUTH_SCOPES=repo read:user user:email
GITHUB_TIMEOUT_SECONDS=30
GITHUB_MAX_RETRIES=3



